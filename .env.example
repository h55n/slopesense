# SlopeSense Environment Configuration
# Copy to .env and fill in your values

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://slopesense:slopesense@localhost:5432/slopesense
REDIS_URL=redis://localhost:6379/0

# ─── NASA Earthdata (free) ───────────────────────────────────────────────────
# Register at: https://urs.earthdata.nasa.gov
NASA_EARTHDATA_USERNAME=your_username
NASA_EARTHDATA_PASSWORD=your_password

# ─── ESA Copernicus (free) ───────────────────────────────────────────────────
# Register at: https://dataspace.copernicus.eu
COPERNICUS_CLIENT_ID=your_client_id
COPERNICUS_CLIENT_SECRET=your_client_secret

# ─── NOAA GFS (no auth required) ────────────────────────────────────────────
NOAA_GFS_BASE_URL=https://nomads.ncep.noaa.gov/cgi-bin/filter_gfs_0p25.pl

# ─── WhatsApp Business API ───────────────────────────────────────────────────
# Meta Business API token (for production use)
WHATSAPP_API_TOKEN=your_meta_business_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_FROM_NUMBER=+91XXXXXXXXXX
WHATSAPP_VERIFY_TOKEN=change_this_webhook_verify_token
WHATSAPP_APP_SECRET=

# ─── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development  # development | staging | production
SECRET_KEY=change_this_to_a_secure_random_string_in_production
INTERNAL_TRIGGER_TOKEN=change_this_to_a_second_secure_random_string
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_HOSTS=localhost,127.0.0.1
API_KEYS=dev-research-key

# ─── Object Storage (S3-compatible) ─────────────────────────────────────────
S3_BUCKET=slopesense-data
S3_ENDPOINT_URL=https://s3.amazonaws.com  # or DigitalOcean Spaces endpoint
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-south-1

# ─── Alert Configuration ─────────────────────────────────────────────────────
FPI_WATCH_THRESHOLD=0.40
FPI_WARNING_THRESHOLD=0.65
FPI_EMERGENCY_THRESHOLD=0.80
ALERT_TEMPORAL_PERSISTENCE_CYCLES=2   # cycles before WhatsApp fires (Watch/Warning)
ALERT_SPATIAL_CLUSTER_FRACTION=0.30   # fraction of cells in block to trigger block alert
CONFIDENCE_SUPPRESSION_WIDTH=0.30     # suppress if CI width > this value

# ─── Scheduler ───────────────────────────────────────────────────────────────
MODEL_RUN_INTERVAL_HOURS=6
SENTINEL2_FETCH_INTERVAL_DAYS=5

# ─── IMD QPF (Plan A — requires formal MoU with MoES) ───────────────────────
IMD_QPF_ENABLED=false
IMD_QPF_API_URL=
IMD_QPF_API_KEY=
